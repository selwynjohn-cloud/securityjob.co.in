# OpenAI Whisper (Expo — local testing only)
EXPO_PUBLIC_OPENAI_API_KEY=

# OTP API base URL reachable from the phone (your Mac LAN IP)
EXPO_PUBLIC_OTP_API_URL=http://192.168.0.166:8787

# Fast2SMS — server only (never EXPO_PUBLIC_)
OTP_PROVIDER=fast2sms
FAST2SMS_API_KEY=
OTP_SERVER_PORT=8787

# Optional Twilio (backup / WhatsApp later)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=
TWILIO_VERIFY_SERVICE_SID=
